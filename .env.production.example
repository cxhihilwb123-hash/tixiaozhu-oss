# Tixiaozhu production environment example.
# Copy values into the real deployment environment. Do not commit real secrets.

TIXIAOZHU_ENV=production
HOST=0.0.0.0
PORT=8787

# Public origins.
FRONTEND_URL=https://app.example.com
ADMIN_URL=https://admin.example.com
CORS_ALLOW_ORIGIN=https://app.example.com,https://admin.example.com

# Frontend/admin build-time API config.
# Omit VITE_API_BASE when frontend, admin, and API are served from the same backend origin.
# Never enable API fallback in production; it is for local demo/dev only.
# VITE_API_BASE=/api
VITE_ENABLE_API_FALLBACK=false

# Production data layer.
TIXIAOZHU_DATA_LAYER=postgres
DATABASE_URL=postgres://user:password@db.example.com:5432/tixiaozhu
TIXIAOZHU_DATABASE_TABLE=tixiaozhu_store

# Admin security.
ADMIN_USERNAME=ops-admin
# Generate with: printf %s "$ADMIN_PASSWORD" | npm --prefix backend run admin:hash-password
ADMIN_PASSWORD_HASH=$2b$12$replace-with-real-bcrypt-hash
ADMIN_SESSION_SECRET=replace-with-64-byte-random-secret
ADMIN_LOGIN_MAX_ATTEMPTS=8
ADMIN_LOGIN_WINDOW_MS=600000

# Student account sessions.
STUDENT_SESSION_SECRET=replace-with-different-64-byte-random-secret
STUDENT_SESSION_TTL_MS=2592000000
REQUIRE_STUDENT_AUTH=true
STUDENT_LOGIN_MAX_ATTEMPTS=10
STUDENT_LOGIN_WINDOW_MS=600000

# Payment launch strategy.
# Use "deferred" while commercial payment is not in this release.
# In deferred mode, keep the payment entry disabled and do not expose mock payments.
PAYMENT_LAUNCH_STRATEGY=deferred

# Payment provider and callback verification.
# Required only when PAYMENT_LAUNCH_STRATEGY=production.
# PAYMENT_PROVIDER_MODE=wechat_pay
# WECHAT_PAY_MCH_ID=replace-with-merchant-id
# WECHAT_PAY_APP_ID=replace-with-app-id
# WECHAT_PAY_SERIAL_NO=replace-with-platform-certificate-serial
# WECHAT_PAY_PRIVATE_KEY=replace-with-private-key-reference
# PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-signing-secret

# AI question generation and photo recognition.
AI_PROVIDER=production-configured
AI_API_BASE=https://api.deepseek.com
AI_API_KEY=replace-with-deepseek-api-key
AI_MODEL=deepseek-v4-flash
# Use "deferred" while photo recognition is not in this release.
# When set to deferred, production hides photo/album recognition and keeps manual input.
OCR_LAUNCH_STRATEGY=deferred
# Required only when OCR_LAUNCH_STRATEGY=production.
# OCR_API_URL=https://ocr-provider.example.com/recognize

# Object storage for uploaded images, generated PDFs, and durable exports.
# If using Vercel Blob, configure a project Blob store and set:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
#
# If using S3/COS-compatible storage, use the fields below instead:
OBJECT_STORAGE_BUCKET=tixiaozhu-prod-assets
OBJECT_STORAGE_REGION=replace-with-region
OBJECT_STORAGE_ENDPOINT=https://storage.example.com
OBJECT_STORAGE_ACCESS_KEY=replace-with-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-secret-key

# Monitoring and alerting.
VERCEL_ALERTS_ENABLED=true
SENTRY_DSN=https://replace-with-sentry-dsn
LOG_DRAIN_URL=https://logs.example.com/ingest
OBSERVABILITY_ENDPOINT=https://observability.example.com/events

# Production boot guard.
# Keep this unset in real production. Use true only for isolated smoke tests.
# ALLOW_BLOCKED_PRODUCTION_START=true
